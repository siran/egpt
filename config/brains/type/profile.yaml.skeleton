# Brain profile skeleton — copy to ~/.egpt/brains/<name>.yaml and fill in.
# Fields marked (required) must be present. Others are optional.

# (required) Display name; also used as the default session handle in the room.
name: myop

# (required) Brain type. One of:
#   codex        OpenAI Codex CLI subprocess
#   ccode        Anthropic Claude Code CLI subprocess
#   cdp_chat     ChatGPT.com tab driven via CDP
#   cdp_claude   Claude.ai tab driven via CDP
type: codex

# ── OPERATOR FIELDS (codex / ccode) ──────────────────────────────────────────

# Model name passed to the CLI (codex only; ccode uses its own model settings).
# Examples: gpt-5.4-mini  gpt-5.4  gpt-5.5
model: gpt-5.4-mini

# Reasoning effort (codex only): low | medium | high
effort: medium

# Working directory for the operator subprocess.
# Supports ~ expansion. Defaults to egpt's own cwd if omitted.
cwd: ~/src/myproject

# Named thread / conversation ID to resume (codex --thread; ccode --resume).
# Leave blank to start fresh each session.
summary:

# ── WEB BRAIN FIELDS (cdp_chat / cdp_claude) ─────────────────────────────────

# Conversation URL or UUID. Use /profile <name> <url> to generate this
# automatically from a live ChatGPT or Claude tab.
# Example: https://chatgpt.com/c/69f68099-5cf8-8328-ad8f-37d991ff0071
url:

# Human-readable label shown in /sessions (optional).
chat_name:

# ── IDENTITY (any type) ──────────────────────────────────────────────────────

# Emoji avatar. Auto-assigned from the palette if omitted.
emoji:

# Short bio shown in /sessions and /rules (optional).
bio:
