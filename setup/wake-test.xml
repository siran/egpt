<?xml version="1.0"?>
<!--
  wake-test.xml — minimal scheduled task to verify that this laptop can be
  woken from sleep by Task Scheduler every PT5M. No egpt code involved.
  Each fire writes one timestamped line to C:\Users\an\wake-test.log.

  Differences from egpt-spine.xml:
    - RunOnlyIfNetworkAvailable=false   (we explicitly want the task to fire
                                         regardless of NIC state, so we can
                                         tell wake-timer-refused from
                                         network-not-yet-available)
    - LogonType=InteractiveToken        (no S4U/password handshake; runs as
                                         the currently logged-in user)
    - The action is a one-line PowerShell append, no working directory,
      no engine, no node.

  To import (Administrator):
    schtasks /Create /XML "C:\Users\an\src\egpt\setup\wake-test.xml" /TN wake-test

  After importing, the first fire happens within ~1 min. Then close the lid,
  wait 20+ minutes asleep, wake the laptop, and read the log:
    type C:\Users\an\wake-test.log

  Lines spaced ~5 min apart that span the sleep window mean wake works.
  Only the pre-sleep + post-wake lines mean wake is being refused at the
  OS / policy layer (independent of egpt).

  To remove:
    schtasks /Delete /TN wake-test /F
    del C:\Users\an\wake-test.log
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Author>egpt</Author>
    <URI>\wake-test</URI>
    <Description>Diagnostic: can Windows wake this laptop from Modern Standby for a scheduled job? Each fire appends a timestamp + network state line to ~/wake-test.log. Standalone (no egpt code) so it isolates wake-timer policy / firmware behavior from anything egpt does. Used 2026-06-05 to characterize this Ryzen 7 7730U's Modern Standby DRIPS rebasing; the production supervisor is now the NSSM 'egpt-daemon' service, so this task should ONLY be installed when diagnosing again.</Description>
  </RegistrationInfo>
  <Triggers>
    <!-- Single PT1M trigger. The 4-staggered "brute-force" variant in
         git history (commit pre-2026-06-06 cleanup) was a one-time
         diagnostic to characterize Windows timer-coalescing under
         Modern Standby; not useful operationally and not committed
         back into the tree once the answer was known. If you need to
         diagnose again, bump this to PT5M or PT10M depending on what
         you're testing. -->
    <TimeTrigger>
      <StartBoundary>2026-01-01T00:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <Repetition>
        <Interval>PT1M</Interval>
        <StopAtDurationEnd>false</StopAtDurationEnd>
      </Repetition>
    </TimeTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <UserId>REVE\an</UserId>
      <LogonType>Password</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>false</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <UseUnifiedSchedulingEngine>true</UseUnifiedSchedulingEngine>
    <WakeToRun>true</WakeToRun>
    <ExecutionTimeLimit>PT1M</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>cmd.exe</Command>
      <Arguments>/c "C:\Users\an\src\egpt\setup\wake-test.cmd"</Arguments>
      <WorkingDirectory>C:\Users\an</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
