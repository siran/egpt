{
  "manifest_version": 3,
  "name": "egpt",
  "version": "0.0.1",
  "description": "Multi-brain AI orchestrator — browser extension",
  "permissions": ["storage", "tabs", "debugger"],
  "host_permissions": [
    "http://localhost:*/",
    "ws://localhost:*/",
    "https://api.telegram.org/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content/wa-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open egpt"
  },
  "options_ui": {
    "page": "settings/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["bus.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
